# ---------------------------------------------------------------------------
# KPI Dashboard - environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Application
APP_ENV=local            # local | staging | production
APP_DEBUG=true           # set to false in production (hides error details)
APP_TIMEZONE=America/New_York

# Primary KPI database (the schema created by sql/schema.sql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kpi_dashboard
DB_USER=kpi_app
DB_PASS=change_me
DB_CHARSET=utf8mb4

# Simple shared-secret guard for the write REST API.
# Requests to POST endpoints must send header:  X-API-Key: <this value>
# Leave blank to disable the check (NOT recommended outside local dev).
API_KEY=

# ---------------------------------------------------------------------------
# Source systems (read-only) - used later when we pull live data via API/ETL.
# These are placeholders; fill in when the connections are provisioned.
# ---------------------------------------------------------------------------
# PRIMS (Clifton) - e.g. RajDB_CLF
PRIMS_DB_HOST=
PRIMS_DB_PORT=1433
PRIMS_DB_NAME=
PRIMS_DB_USER=
PRIMS_DB_PASS=

# SAP HANA (PRODHANA)
PRODHANA_DB_HOST=
PRODHANA_DB_PORT=30015
PRODHANA_DB_NAME=
PRODHANA_DB_USER=
PRODHANA_DB_PASS=
