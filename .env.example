# ---------------------------------------------------------------------------
# KPI Dashboard - environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Application
APP_ENV=local            # local | staging | production
APP_DEBUG=false          # NEVER set to true in production (leaks stack traces)
APP_TIMEZONE=America/New_York

# Primary KPI database (the schema created by sql/schema.sql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kpi_dashboard
DB_USER=kpi_app
DB_PASS=change_me
DB_CHARSET=utf8mb4

# API authentication (shared-secret).  All /api/* requests require this key
# in the X-API-Key header.  MUST be set in staging/production — the server
# will refuse to start if APP_ENV != local and this is blank.
API_KEY=

# CORS: origin allowed to call the API (e.g. https://dashboard.example.com).
# Leave blank to deny all cross-origin requests (safest default).
CORS_ORIGIN=

# ---------------------------------------------------------------------------
# Source systems (read-only) - used later when we pull live data via API/ETL.
# Data is pulled from PRIMSBM and PRODHANA. Fill in when provisioned.
# ---------------------------------------------------------------------------
# PRIMSBM  (driver: sqlsrv on Windows/XAMPP, dblib on Linux, or mysql for testing)
PRIMSBM_DB_DRIVER=sqlsrv
PRIMSBM_DB_HOST=192.168.100.5
PRIMSBM_DB_PORT=1433
PRIMSBM_DB_NAME=PRIMSBM
PRIMSBM_DB_USER=
PRIMSBM_DB_PASS=

# PRODHANA (SAP HANA; driver: odbc via the HANA ODBC DSN)
PRODHANA_DB_DRIVER=odbc
PRODHANA_DB_HOST=192.168.100.5
PRODHANA_DB_PORT=30015
PRODHANA_DB_NAME=PRODHANA
PRODHANA_DB_USER=
PRODHANA_DB_PASS=
