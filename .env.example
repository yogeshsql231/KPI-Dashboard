# ---------------------------------------------------------------------------
# KPI Dashboard - environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Application
APP_ENV=local            # local | staging | production
APP_DEBUG=true           # set to false in production (hides error details)
APP_TIMEZONE=America/New_York

# Primary KPI database (the schema created by sql/schema.sql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kpi_dashboard
DB_USER=kpi_app
DB_PASS=change_me
DB_CHARSET=utf8mb4

# Simple shared-secret guard for the write REST API.
# Requests to POST endpoints must send header:  X-API-Key: <this value>
# Leave blank to disable the check (NOT recommended outside local dev).
API_KEY=

# ---------------------------------------------------------------------------
# Dashboard sign-in (C-level access restriction).
#   AUTH_ENABLED=false -> turn the login OFF entirely: no sign-in required and
#                         all panels are visible (pre-auth behaviour). Use this
#                         until LDAP is fully configured/working.
#   AUTH_ENABLED=true  -> require sign-in (default).
#   AUTH_DRIVER=ldap   -> authenticate against on-prem LDAP / Active Directory.
#   AUTH_DRIVER=dev    -> LOCAL TESTING ONLY: accept DEV_PASSWORD for any user.
# Users in the C-level group additionally see the financial panels (Order/
# Delivered Value tiles and the Late Pay block); everyone else sees only the
# operational KPIs. Requires the php-ldap extension for the ldap driver.
# ---------------------------------------------------------------------------
AUTH_ENABLED=true
AUTH_DRIVER=ldap

# LDAP / Active Directory connection.
# LDAP_URL     : ldap://host or ldaps://host[:port] reachable from this server.
# LDAP_START_TLS: true to upgrade a plain ldap:// connection to TLS.
# LDAP_BIND_PATTERN: how a username maps to a bind DN. %s = the entered name.
#   Active Directory examples:  "%s@corp.damascusbakery.com"  or  "DAMASCUS\\%s"
#   OpenLDAP example:           "uid=%s,ou=people,dc=damascusbakery,dc=com"
# LDAP_BASE_DN : where to search for the user entry (for name + groups).
# LDAP_USER_FILTER: search filter; %s = the entered name. AD uses sAMAccountName.
# LDAP_CLEVEL_GROUP: the group (CN or full DN) whose members are "C-level".
LDAP_URL=ldap://dc01.damascusbakery.com
LDAP_START_TLS=false
LDAP_BIND_PATTERN=%s@corp.damascusbakery.com
LDAP_BASE_DN=dc=corp,dc=damascusbakery,dc=com
LDAP_USER_FILTER=(sAMAccountName=%s)
LDAP_CLEVEL_GROUP=KPI C-Level

# Local dev login (used only when AUTH_DRIVER=dev). Never enable in production.
DEV_PASSWORD=
DEV_CLEVEL_USERS=

# ---------------------------------------------------------------------------
# Source systems (read-only) - used later when we pull live data via API/ETL.
# Data is pulled from PRIMSBM and PRODHANA. Fill in when provisioned.
# ---------------------------------------------------------------------------
# PRIMSBM  (driver: sqlsrv on Windows/XAMPP, dblib on Linux, or mysql for testing)
PRIMSBM_DB_DRIVER=sqlsrv
PRIMSBM_DB_HOST=192.168.100.5
PRIMSBM_DB_PORT=1433
PRIMSBM_DB_NAME=PRIMSBM
PRIMSBM_DB_USER=
PRIMSBM_DB_PASS=

# PRODHANA (SAP HANA; driver: odbc via the HANA ODBC DSN)
PRODHANA_DB_DRIVER=odbc
PRODHANA_DB_HOST=192.168.100.5
PRODHANA_DB_PORT=30015
PRODHANA_DB_NAME=PRODHANA
PRODHANA_DB_USER=
PRODHANA_DB_PASS=
